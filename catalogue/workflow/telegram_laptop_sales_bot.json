        "jsCode": "const category = $('Save Category + Chat ID').first().json.category;\nconst chatId = $('Save Category + Chat ID').first().json.chat_id;\nconst messageId = $('Save Category + Chat ID').first().json.message_id;\nconst firstName = $('Save Category + Chat ID').first().json.first_name;\n\nreturn [{\n  json: {\n    chat_id: chatId,\n    message_id: messageId,\n    category: category,\n    first_name: firstName\n  }\n}];"
