    {
      "parameters": {
        "jsCode": "const allLaptops = $input.all().map(item => item.json);\n\nconst budgetTier = $('Extract Budget + Category').first().json.budget_tier;\nconst category = $('Extract Budget + Category').first().json.category;\nconst chatId = $('Extract Budget + Category').first().json.chat_id;\nconst firstName = $('Extract Budget + Category').first().json.first_name;\n\nconst matches = allLaptops.filter(laptop => {\n  const categories = laptop.categories\n    ? laptop.categories.toLowerCase().split(',').map(c => c.trim())\n    : [];\n  const inCategory = categories.includes(category.toLowerCase());\n  const inBudget = laptop.budget_tier === budgetTier;\n  const inStock = laptop.in_stock === true || \n                  laptop.in_stock === 'TRUE';\n  return inCategory && inBudget && inStock;\n});\n\nconst top3 = matches.slice(0, 3);\nconst reasonKey = `reason_${category.toLowerCase()}`;\n\nif (top3.length === 0) {\n  return [{\n    json: {\n      text: '😔 No exact matches found right now.',\n      chat_id: chatId,\n      first_name: firstName,\n      has_results: false,\n      is_last: true\n    }\n  }];\n}\n\n// Build all messages as a single combined text\nconst allMessages = top3.map((laptop, index) => {\n  const price = Number(laptop.price).toLocaleString('en-NG');\n  const reason = laptop[reasonKey] || 'Great match for your needs.';\n  const gpu = laptop.gpu ? `🎮 *GPU:* ${laptop.gpu}\\n` : '';\n\n  return `*${index + 1}. ${laptop.name}*\\n\\n` +\n    `🔧 *CPU:* ${laptop.cpu}\\n` +\n    `💾 *RAM:* ${laptop.ram}\\n` +\n    `💿 *Storage:* ${laptop.storage}\\n` +\n    `${gpu}` +\n    `💰 *Price:* ₦${price}\\n\\n` +\n    `✅ _${reason}_`;\n});\n\n// Return ONE item with all recommendations combined\nreturn [{\n  json: {\n    text: allMessages.join('\\n\\n─────────────────\\n\\n'),\n    chat_id: chatId,\n    first_name: firstName,\n    has_results: true\n  }\n}];"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
